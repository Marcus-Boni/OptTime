# ─────────────────────────────────────────────────────────────────────────────
# URL pública da aplicação (sem barra final)
# Desenvolvimento: http://localhost:3000
# Produção:        https://your-app.azurewebsites.net
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Banco de Dados (Azure Database for PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
# Use a connection string copiada do Azure Portal (Connection strings)
# Exemplo:
# postgresql://app_user:password@my-server.postgres.database.azure.com:5432/opt-timer?sslmode=require
DATABASE_URL="postgresql://app_user:password@my-server.postgres.database.azure.com:5432/opt-timer?sslmode=require"

# Opcional: ajuste fino de pool/SSL (recomendado para produção)
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_SSL_REJECT_UNAUTHORIZED=true

# ─────────────────────────────────────────────────────────────────────────────
# Better Auth
# BETTER_AUTH_SECRET: string aleatório seguro (min 32 chars)
#   Gerar: openssl rand -base64 32
# BETTER_AUTH_URL: deve ser igual a NEXT_PUBLIC_APP_URL
# ─────────────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="sua-chave-secreta"
BETTER_AUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────────────────
# Microsoft OAuth (Azure AD)
# Redirect URI a registrar no Azure Portal:
#   https://your-app.azurewebsites.net/api/auth/callback/microsoft
# Tenant ID:
#   diretório Microsoft Entra onde o app registration foi criado
# ─────────────────────────────────────────────────────────────────────────────
MICROSOFT_TENANT_ID="..."
MICROSOFT_CLIENT_ID="..."
MICROSOFT_CLIENT_SECRET="..."
MICROSOFT_CLIENT_SECRET_ID="..."

# ─────────────────────────────────────────────────────────────────────────────
# Email transacional (Resend — https://resend.com)
# Em produção: verificar o domínio em resend.com/domains
# e usar um remetente do domínio verificado, ex: noreply@optsolv.com.br
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="OptSolv Time <noreply@optsolv.com.br>"

# ─────────────────────────────────────────────────────────────────────────────
# Chave de criptografia AES-256 dos PATs do Azure DevOps
# OBRIGATÓRIO em produção — deve ser idêntico em todos os deployments para que
# os PATs já gravados no banco possam ser descriptografados corretamente.
# Se não definido, faz fallback para BETTER_AUTH_SECRET.
# ObrigatÃ³rio tambÃ©m em desenvolvimento; nÃ£o existe fallback seguro.
# Gerar: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Cron secret for POST /api/cron/reminders
# Shared between the app and the external scheduler (GitHub Actions, Azure, etc.)
# Generate: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────
CRON_SECRET="RRoNUiu0GUe52aN8e+2XX+RVF7yc+qj04xjG+zdwMFE="
