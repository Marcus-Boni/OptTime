{
  "name": "optsolv-time-tracker-azdo-extension",
  "version": "1.1.10",
  "private": true,
  "description": "OptSolv Time Tracker — Azure DevOps Extension",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "package": "npm run build && tfx extension create --manifest-globs vss-extension.json --output-path dist/vsix"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.0.4",
    "azure-devops-extension-sdk": "^4.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "tfx-cli": "^0.16.0"
  }
}
